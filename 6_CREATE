--UNIQUE : 입력 값에 대한 중복 제한
CREATE TABLE USER_UNIQUE(
    USER_NO NUMBER UNIQUE,--컬럼 레벨 제약조건 설정
    USER_ID VARCHAR2(20),
    USER_PWD VARCHAR2(30) NOT NULL, --not null은 컬럼레벨에서만 제약조건 가능
    USER_NAME VARCHAR2(30)NOT NULL,
