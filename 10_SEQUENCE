-- SEQUENCE : 자동 번호 발생기
-- 순차적으로 정수 값을 자동으로 생성
-- 표현식
-- CREATE SEQUENCE 시퀀스이름
-- [INCREMENT BY 숫자]            : 다음 값에 대한 증가치, 생략되면 자동 1
-- [START WITH 숫자]              : 처음 발생시킬 시작 값, 생략되면 자동1
-- [MAXVALUE 숫자 | NOMAXVALUE]   : 발생시킬 최대 값, 생략되면 10의 27승 -1
-- [MINVALUE 숫자 | NOMINVALUE]   : 발생시킬 최소 값, 생략되면 -10의 26승 
-- [CYCLE | NOCYCLE]              : 값 순환 여부, CYCLE이면 최대 값이 넘었을 때 다시 최소 값으로 돌아감
-- [CACHE 바이트크기 | NOCACHE]    : 캐시 메모리 지정 기본 20바이트, 최소 2바이트

CREATE SEQUENCE SEQ_TEST
START WITH 300
INCREMENT BY 5
MAXVALUE 320
NOCYCLE
NOCACHE;

SELECT * FROM USER_SEQUENCES;

--SEQUENCE 사용
--시퀀스명.CURRVAL : 현재 생성된 시퀀스의 값
--시퀀스명.NEXTVAL : 최초로 시퀀스를 실행시키거나 기존 시퀀스 값에서 증가치만큼 증가한 값

SELECT SEQ_TEST.CURRVAL FROM DUAL;
--ORA-08002: 시퀀스 SEQ_TEST.CURRVAL은 이 세션에서는 정의 되어 있지 않습니다
SELECT SEQ_TEST.NEXTVAL FROM DUAL;

--SEQUENCE 변경
--ALTER SEQUENCE 시퀀스 이름
-- [INCREMENT BY 숫자]
-- [MAXVALUE 숫자 | NOMAXVALUE]
-- [MINVALUE 숫자 | NOMINVALUE]
-- [CYCLE | NOCYCLE]
-- [CACHE 바이트 크기 | NOCACHE]

ALTER SEQUENCE SEQ_TEST
INCREMENT BY 20
MAXVALUE 400
MINVALUE 200
CYCLE;

SELECT * FROM USER_SEQUENCES;
SELECT SEQ_TEST.CURRVAL FROM DUAL;
SELECT SEQ_TEST.NEXTVAL FROM DUAL;

--사용 예시
insert into employee
values(seq_test.nextval, '테스트','123456-1234567', 'EMAIL','PHONE','D2','J7','S1',
        5000000, 0.1 ,200 , SYSDATE , NULL  ,DEFAULT);
ROLLBACK;

CREATE TABLE TMP_EMPLOYEE(
    E_ID NUMBER DEFAULT SEQ_TEST.NEXTVAL,
    E_NAME VARCHAR2(30)
);

